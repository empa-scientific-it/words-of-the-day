---
import { actions } from "astro:actions";
import { languages, partsOfSpeech } from "../config";

interface Props {
    success?: boolean;
    prUrl?: string;
    debug?: { input: Record<string, unknown>; slug: string; branch: string; filePath: string; markdown: string };
    errors?: Record<string, string[] | undefined>;
    serverError?: string;
}

const { success, prUrl, debug, errors, serverError } = Astro.props;
const langEntries = Object.entries(languages);
---

{
    success && (
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 mb-6 text-sm">
            Word submitted!
            {prUrl && (
                <a
                    href={prUrl}
                    target="_blank"
                    rel="noopener"
                    class="underline font-medium ml-1"
                >
                    View the pull request &rarr;
                </a>
            )}
        </div>
    )
}

{
    debug && (
        <details open class="bg-violet-50 border border-violet-200 rounded-lg px-4 py-3 mb-6 text-sm">
            <summary class="font-medium text-violet-800 cursor-pointer">
                Dev: {debug.filePath} &rarr; branch <code>{debug.branch}</code>
            </summary>
            <pre class="mt-3 p-3 bg-white border border-violet-100 rounded text-xs overflow-x-auto whitespace-pre-wrap">{debug.markdown}</pre>
        </details>
    )
}

{
    serverError && (
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 mb-6 text-sm">
            {serverError}
        </div>
    )
}

{
    errors && (
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 mb-6 text-sm">
            Please fix the errors below.
        </div>
    )
}

<form method="POST" action={actions.submit} class="space-y-6">
    <div>
        <label for="word" class="block text-sm font-medium mb-1">Word *</label>
        <input
            type="text"
            id="word"
            name="word"
            required
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
        />
        {
            errors?.word && (
                <p class="text-red-600 text-xs mt-1">{errors.word[0]}</p>
            )
        }
    </div>

    <div>
        <label for="meaning" class="block text-sm font-medium mb-1"
            >Meaning *</label
        >
        <textarea
            id="meaning"
            name="meaning"
            required
            rows="3"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
        ></textarea>
        {
            errors?.meaning && (
                <p class="text-red-600 text-xs mt-1">{errors.meaning[0]}</p>
            )
        }
    </div>

    <div>
        <label for="partOfSpeech" class="block text-sm font-medium mb-1"
            >Part of Speech</label
        >
        <select
            id="partOfSpeech"
            name="partOfSpeech"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
        >
            <option value="">Select...</option>
            {partsOfSpeech.map((pos) => <option value={pos}>{pos}</option>)}
        </select>
    </div>

    <fieldset class="space-y-4">
        <legend class="text-sm font-medium">Translations</legend>
        {
            langEntries.map(([key, { name, emoji }]) => (
                <div>
                    <label for={key} class="block text-xs text-stone-500 mb-1">
                        {emoji} {name}
                    </label>
                    <input
                        type="text"
                        id={key}
                        name={key}
                        class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
                    />
                </div>
            ))
        }
    </fieldset>

    <div>
        <label for="body" class="block text-sm font-medium mb-1">Notes</label>
        <p class="text-xs text-stone-400 mb-1">
            Examples, usage notes, etymology — Markdown supported.
        </p>
        <textarea
            id="body"
            name="body"
            rows="4"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-stone-400"
        ></textarea>
    </div>

    <div class="flex items-center gap-2">
        <input
            type="checkbox"
            id="favourite"
            name="favourite"
            class="rounded"
        />
        <label for="favourite" class="text-sm">Mark as favourite</label>
    </div>

    <button
        type="submit"
        class="bg-stone-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-stone-700 transition-colors"
    >
        Submit Word
    </button>
</form>
