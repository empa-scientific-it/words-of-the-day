---
import PartOfSpeechBadge from "./PartOfSpeechBadge.astro";
import { Star, CircleAlert } from "@lucide/astro";

interface Props {
  word: string;
  slug: string;
  meaning?: string;
  partOfSpeech: string[];
  languages: {
    name: string;
    emoji: string;
    word: string;
    gender?: string;
    transliteration?: string;
  }[];
  favourite: boolean;
  isComplete: boolean;
  featured: Date;
}

const {
  word,
  slug,
  meaning,
  partOfSpeech,
  languages,
  favourite,
  isComplete,
  featured,
} = Astro.props;

const featuredStr = featured.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<a
  href={`/${slug}`}
  class="block border border-stone-200 rounded-lg p-5 bg-white hover:shadow-md transition-shadow"
>
  <div class="flex items-start justify-between gap-2 mb-2">
    <h2 class="text-lg font-semibold leading-tight">{word}</h2>
    <div class="flex items-center gap-2 shrink-0">
      {
        !isComplete && (
          <span
            class="inline-flex items-center gap-1 text-xs bg-red-100 text-red-600 px-1.5 py-0.5 rounded-full"
            title="Incomplete: missing translations"
          >
            <CircleAlert size={12} />
          </span>
        )
      }
      {
        favourite && (
          <span
            class="inline-flex items-center bg-amber-100 text-amber-600 px-1.5 py-0.5 rounded-full"
            title="Favourite"
          >
            <Star size={12} fill="currentColor" />
          </span>
        )
      }
      <span class="text-xs text-stone-400">{featuredStr}</span>
    </div>
  </div>
  <div class="flex gap-1.5 mb-2">
    {partOfSpeech.map((pos) => <PartOfSpeechBadge pos={pos} />)}
  </div>
  {meaning && <p class="text-sm text-stone-600 mb-3 line-clamp-2">{meaning}</p>}
  {
    languages.length > 0 && (
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-stone-500">
        {languages.map((lang) => (
          <span>
            {lang.emoji} {lang.word}
          </span>
        ))}
      </div>
    )
  }
</a>
