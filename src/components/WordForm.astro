---
import { actions } from "astro:actions";
import { languages, partsOfSpeech, posStyles, genders } from "../config";
import type { LangEntry } from "../schema";

interface WordData {
  slug: string;
  word: string;
  meaning?: string | null;
  partOfSpeech?: unknown;
  origin?: string | null;
  languages?: unknown;
  favourite?: boolean;
  featured?: Date;
  body?: string | null;
  relatedWords?: unknown;
}

interface Props {
  action: "submit" | "update";
  word?: WordData;
  allWords?: { slug: string; word: string }[];
  success?: boolean;
  slug?: string;
  errors?: Record<string, string[] | undefined>;
  serverError?: string;
}

const { action, word, allWords, success, slug, errors, serverError } =
  Astro.props;

const isEdit = action === "update";
const formAction = isEdit ? actions.update : actions.submit;
const langEntries = Object.entries(languages);

const currentPos = (word?.partOfSpeech as string[]) ?? [];
const currentLangs = (word?.languages ?? {}) as Record<string, LangEntry>;
const currentFeatured = word?.featured
  ? word.featured.toISOString().split("T")[0]
  : "";

const currentRelated = (word?.relatedWords ?? []) as string[];
const wordsBySlug = new Map(allWords?.map((w) => [w.slug, w.word]));
---

{
  success && (
    <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 mb-6 text-sm">
      {isEdit ? "Word updated!" : "Word saved!"}
      {(slug || word?.slug) && (
        <a href={`/${slug || word?.slug}`} class="underline font-medium ml-1">
          View it &rarr;
        </a>
      )}
    </div>
  )
}

{
  serverError && (
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 mb-6 text-sm">
      {serverError}
    </div>
  )
}

{
  errors && (
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 mb-6 text-sm">
      Please fix the errors below.
    </div>
  )
}

<form method="POST" action={formAction} class="space-y-6">
  {isEdit && <input type="hidden" name="slug" value={word!.slug} />}

  <div>
    <label for="word" class="block text-sm font-medium mb-1">Word *</label>
    <input
      type="text"
      id="word"
      name="word"
      required
      value={word?.word ?? ""}
      class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
    />
    {errors?.word && <p class="text-red-600 text-xs mt-1">{errors.word[0]}</p>}
  </div>

  <div>
    <label for="meaning" class="block text-sm font-medium mb-1">
      Meaning
    </label>
    <textarea
      id="meaning"
      name="meaning"
      rows="3"
      class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
      >{word?.meaning ?? ""}</textarea
    >
  </div>

  <fieldset>
    <legend class="block text-sm font-medium mb-2">Part of Speech</legend>
    <pos-picker data-styles={JSON.stringify(posStyles)}>
      <div class="flex flex-wrap gap-2">
        {
          partsOfSpeech.map((p) => {
            const s = posStyles[p];
            const isChecked = currentPos.includes(p);
            return (
              <label class="cursor-pointer">
                <input
                  type="checkbox"
                  name="partOfSpeech"
                  value={p}
                  checked={isChecked}
                  class="sr-only peer"
                />
                <span
                  class:list={[
                    "chip",
                    isChecked ? s.active : [s.base, s.hover],
                  ]}
                >
                  {p}
                </span>
              </label>
            );
          })
        }
      </div>
    </pos-picker>
  </fieldset>

  <fieldset class="space-y-5">
    <legend class="text-sm font-medium">Translations</legend>
    {
      langEntries.map(([key, { name, emoji }]) => {
        const entry = currentLangs[key];
        return (
          <div class="space-y-2">
            <label class="block text-xs text-stone-500">
              {emoji} {name}
            </label>
            <input
              type="text"
              name={`${key}_word`}
              placeholder="Translation"
              value={entry?.word ?? ""}
              class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
            />
            <div class="flex gap-2">
              <input
                type="text"
                name={`${key}_transliteration`}
                placeholder="Transliteration"
                value={entry?.transliteration ?? ""}
                class="flex-1 border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
              />
              <select
                name={`${key}_gender`}
                class="border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <option value="">Gender</option>
                {genders.map((g) => (
                  <option value={g} selected={entry?.gender === g}>
                    {g}
                  </option>
                ))}
              </select>
            </div>
          </div>
        );
      })
    }
  </fieldset>

  <div>
    <label for="body" class="block text-sm font-medium mb-1">Notes</label>
    <p class="text-xs text-stone-400 mb-1">
      Examples, usage notes, etymology — Markdown supported.
    </p>
    <textarea
      id="body"
      name="body"
      rows="4"
      class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-stone-400"
      >{word?.body ?? ""}</textarea
    >
  </div>

  <div>
    <label for="related-words" class="block text-sm font-medium mb-1"
      >Related Words</label
    >
    <related-picker>
      <input
        type="text"
        list="related-words-list"
        class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
      />
      <div id="relatedWords" class="flex flex-wrap gap-2 mt-2">
        {
          currentRelated.map((w) => (
            <div class="inline-flex">
              <input type="hidden" name="relatedWords" value={w} />
              <span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-stone-100 text-stone-700">
                {wordsBySlug.get(w) ?? w}
                <button type="button" class="ml-1" aria-label="Remove">
                  ×
                </button>
              </span>
            </div>
          ))
        }
      </div>
    </related-picker>
    <datalist id="related-words-list">
      {
        allWords
          ?.filter((w) => w.slug !== word?.slug)
          .map((w) => <option value={w.slug}>{w.word}</option>)
      }
    </datalist>
  </div>

  <div>
    <label for="featured" class="block text-sm font-medium mb-1">
      Featured date
    </label>
    <p class="text-xs text-stone-400 mb-1">
      When this word was picked as word of the day. Defaults to today.
    </p>
    <input
      type="date"
      id="featured"
      name="featured"
      value={currentFeatured}
      class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
    />
  </div>

  <div class="flex items-center gap-2">
    <input
      type="checkbox"
      id="favourite"
      name="favourite"
      checked={word?.favourite ?? false}
      class="rounded"
    />
    <label for="favourite" class="text-sm">Mark as favourite</label>
  </div>

  <div class="flex items-center justify-between">
    <button
      type="submit"
      class="bg-stone-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-stone-700 transition-colors"
    >
      {isEdit ? "Save Changes" : "Submit Word"}
    </button>
    {
      isEdit && (
        <button
          type="submit"
          formaction={`${actions.remove}`}
          class="bg-red-600 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-red-700 transition-colors"
          onclick="return confirm('Delete this word permanently?')"
        >
          Delete
        </button>
      )
    }
  </div>

  <style>
    @reference "tailwindcss";
    .chip {
      @apply inline-block text-xs font-medium px-3 py-1 rounded-full transition-colors;
    }
  </style>

  <script>
    class PosPicker extends HTMLElement {
      connectedCallback() {
        const styles = JSON.parse(this.dataset.styles!);
        const form = this.closest("form")!;
        const genderSelects = form.querySelectorAll<HTMLSelectElement>(
          "select[name$='_gender']",
        );

        const syncGenderState = () => {
          const checked = [
            ...this.querySelectorAll<HTMLInputElement>("input:checked"),
          ].map((i) => i.value);
          const hasNoun = checked.includes("Noun");
          genderSelects.forEach((sel) => {
            sel.disabled = !hasNoun;
            if (!hasNoun) sel.value = "";
          });
        };

        this.querySelectorAll("input").forEach((input) => {
          input.addEventListener("change", () => {
            const span = input.nextElementSibling as HTMLElement;
            const s = styles[input.value];
            if (!s) return;
            const all = [
              ...s.base.split(" "),
              ...s.hover.split(" "),
              ...s.active.split(" "),
            ];
            span.classList.remove(...all);
            if (input.checked) {
              span.classList.add(...s.active.split(" "));
            } else {
              span.classList.add(...s.base.split(" "), ...s.hover.split(" "));
            }
            syncGenderState();
          });
        });

        syncGenderState();
      }
    }

    customElements.define("pos-picker", PosPicker);

    class RelatedPicker extends HTMLElement {
      connectedCallback() {
        const input = this.querySelector(
          "input[type='text']",
        ) as HTMLInputElement;
        const relatedWords = this.querySelector(
          "#relatedWords",
        ) as HTMLDivElement;
        const datalist = document.querySelector(
          "#related-words-list",
        ) as HTMLDataListElement;

        // When the user picks a word from the datalist
        input.addEventListener("change", () => {
          const slug = input.value.trim();
          if (!slug) return;

          // Check if not already added
          const existing = relatedWords.querySelector(`input[value='${slug}']`);
          if (existing) {
            input.value = "";
            return;
          }

          // Check the slug exists in the datalist
          const option = datalist.querySelector(`option[value='${slug}']`);
          if (option) {
            const displayName = option.textContent ?? slug;
            const wrapper = document.createElement("div");
            wrapper.className = "inline-flex";
            wrapper.innerHTML = `
              <input type="hidden" name="relatedWords">
              <span class="inline-block text-xs font-medium px-3 py-1 rounded-full bg-stone-100 text-stone-700">
                <span class="related-label"></span>
                <button type="button" class="ml-1" aria-label="Remove">×</button>
              </span>
            `;
            wrapper.querySelector("input")!.value = slug;
            wrapper.querySelector(".related-label")!.textContent = displayName;
            relatedWords.appendChild(wrapper);
            input.value = "";
          }
        });

        // "Enter" adds the word instead of submitting the form
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            input.dispatchEvent(new Event("change"));
          }
        });

        // Handle remove button clicks on the container
        relatedWords.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          if (target.closest("button")) {
            target.closest(".inline-flex")?.remove();
          }
        });
      }
    }

    customElements.define("related-picker", RelatedPicker);
  </script>
</form>
