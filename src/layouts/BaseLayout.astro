---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Word of the Day" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <nav
        class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between"
      >
        <a
          href="/"
          class="text-lg font-semibold tracking-tight hover:text-stone-600"
        >
          Words of the Day
        </a>
        <div class="flex gap-4 text-sm">
          <a href="/" class="hover:text-stone-600">Words</a>
          <a href="/submit" class="hover:text-stone-600">Submit</a>
        </div>
      </nav>
    </header>
    <main class="max-w-3xl mx-auto px-4 py-8 pb-24">
      <slot />
    </main>
  </body>
</html>
