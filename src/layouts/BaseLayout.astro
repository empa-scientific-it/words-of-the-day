---
import "../styles/global.css";
import { Search } from "@lucide/astro";

interface Props {
  title?: string;
}

const { title = "Word of the Day" } = Astro.props;
const currentQ = Astro.url.searchParams.get("q") ?? "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <nav
        class="max-w-3xl mx-auto px-4 py-4 flex flex-wrap items-center gap-3"
      >
        <a
          href="/"
          class="text-lg font-semibold tracking-tight hover:text-stone-600"
        >
          Words of the Day
        </a>
        <div class="flex items-center gap-4 text-sm ml-auto">
          <a href="/" class="hover:text-stone-600">Words</a>
          <a href="/submit" class="hover:text-stone-600">Submit</a>
        </div>
        <form
          method="GET"
          action="/"
          class="relative w-full sm:w-auto sm:order-none order-last"
        >
          <Search
            size={14}
            class="absolute left-2.5 top-1/2 -translate-y-1/2 text-stone-400"
          />
          <input
            type="text"
            name="q"
            placeholder="Search..."
            value={currentQ}
            class="w-full sm:w-36 pl-8 pr-3 py-1.5 border border-stone-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-stone-400"
          />
        </form>
      </nav>
    </header>
    <main class="max-w-3xl mx-auto px-4 py-8 pb-24">
      <slot />
    </main>
  </body>
</html>
