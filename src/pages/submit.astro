---
export const prerender = false;

import { actions, isInputError } from "astro:actions";
import BaseLayout from "../layouts/BaseLayout.astro";
import SubmissionForm from "../components/SubmissionForm.astro";

const result = Astro.getActionResult(actions.submit);
const success = result && !result.error;
const prUrl = success ? result.data?.prUrl : undefined;
const debug = success ? result.data?.debug : undefined;
const errors =
    result?.error && isInputError(result.error)
        ? result.error.fields
        : undefined;
const serverError =
    result?.error && !isInputError(result.error)
        ? result.error.message
        : undefined;
---

<BaseLayout title="Submit a Word">
    <h1 class="text-2xl font-bold mb-2">Submit a Word</h1>
    <p class="text-stone-500 text-sm mb-8">
        Suggest a new word of the day. Submissions are reviewed before being
        published.
    </p>
    <SubmissionForm
        success={success}
        prUrl={prUrl}
        debug={debug}
        errors={errors}
        serverError={serverError}
    />
</BaseLayout>
