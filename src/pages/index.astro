---
export const prerender = false;

import { getAllWords, enrichLanguages } from "../lib/words";
import BaseLayout from "../layouts/BaseLayout.astro";
import WordCard from "../components/WordCard.astro";

const words = await getAllWords();
---

<BaseLayout>
    <h1 class="text-2xl font-bold mb-6">All Words</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
            words.map((w) => (
                <WordCard
                    word={w.word}
                    slug={w.slug}
                    meaning={w.meaning ?? undefined}
                    partOfSpeech={w.partOfSpeech as string[]}
                    languages={enrichLanguages(w.languages as Record<string, string>)}
                    favourite={w.favourite}
                    featured={w.featured}
                />
            ))
        }
    </div>
</BaseLayout>
